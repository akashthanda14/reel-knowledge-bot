# ── Required — fill in all four before running ────────────────────────────────

# OpenAI API key
# Get it from: https://platform.openai.com/api-keys
# Used for: GPT-4o (AI reasoning), Whisper API (transcription fallback), embeddings
OPENAI_API_KEY=sk-...

# Notion integration secret
# Get it from: https://www.notion.so/my-integrations → New integration → copy "Internal Integration Secret"
NOTION_TOKEN=ntn_...

# Notion database ID
# Get it from your database URL: notion.so/YOUR_WORKSPACE/<THIS_32_CHAR_ID>?v=...
# Must be a database (not a page), shared with your integration
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Telegram bot token
# Get it from @BotFather on Telegram → /newbot → copy the token
TELEGRAM_BOT_TOKEN=123456789:ABCdef-...

# ── Do NOT set these — Docker Compose sets them automatically ─────────────────
# If you ever run outside Docker (e.g. for local testing), uncomment these:
# REDIS_URL=redis://localhost:6379
# QDRANT_URL=http://localhost:6333
